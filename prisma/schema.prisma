generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Application {
  id               String   @id @default(uuid())
  startup_name     String
  team_head        String
  phone            String
  member_count     Int
  members          Json
  description      String
  stage            String
  linkedin_url     String?
  website_url      String?
  pitch_video_url  String?
  pitch_video_path String?
  created_at       DateTime @default(now())

  @@map("applications")
}
